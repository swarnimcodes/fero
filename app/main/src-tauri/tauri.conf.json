{
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [],
    "copyright": "Copyright (C) 2026 Swarnimcodes and contributors. Based on RQuickShare, Copyright (C) 2024 Martin Andre and contributors.",
    "category": "DeveloperTool",
    "shortDescription": "Desktop file sharing compatible with Nearby Share / Quick Share",
    "longDescription": "Fero is a desktop file-sharing app for Linux and macOS that interoperates with Android Nearby Share / Quick Share.",
    "macOS": {
      "frameworks": [],
      "exceptionDomain": "",
      "signingIdentity": "-",
      "providerShortName": null,
      "entitlements": null
    },
    "linux": {
      "deb": {
        "depends": []
      }
    }
  },
  "build": {
    "beforeBuildCommand": "pnpm vite:build",
    "frontendDist": "../dist",
    "beforeDevCommand": "pnpm vite:dev",
    "devUrl": "http://localhost:1420"
