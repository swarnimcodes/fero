  "productName": "fero",
  "identifier": "io.github.swarnimcodes.fero",
  "app": {
    "windows": [
      {
        "title": "Fero",
        "width": 900,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  }
